---
import Layout from '../layouts/Layout.astro';
import { Mail, Send } from '@lucide/astro';
---

<Layout 
  title="Contact Support - ToolVerse"
  description="Get in touch with the ToolVerse team for feedback, bug reports, custom feature requests, or enterprise self-hosted deployment guides."
>
  <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 py-6">
    <!-- Info Column -->
    <div class="space-y-6">
      <div>
        <h1 class="text-3xl font-extrabold text-text-main">Contact Us</h1>
        <p class="text-xs sm:text-sm text-text-muted mt-2">Have suggestions, found a bug, or want to contribute a utility?</p>
      </div>

      <div class="space-y-4">
        <!-- Mail -->
        <a href="mailto:support@toolverse.com" class="glass-card p-4 rounded-xl flex items-center gap-3.5 hover:border-primary/50 transition-colors">
          <div class="h-9 w-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
            <Mail class="h-4.5 w-4.5" />
          </div>
          <div>
            <h3 class="text-xs font-bold text-text-main">Email Support</h3>
            <p class="text-[10px] text-text-muted">support@toolverse.com</p>
          </div>
        </a>

        <!-- Github -->
        <a href="https://github.com" class="glass-card p-4 rounded-xl flex items-center gap-3.5 hover:border-primary/50 transition-colors">
          <div class="h-9 w-9 rounded-lg bg-accent/10 flex items-center justify-center text-accent">
            <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
              <path d="M9 18c-4.51 2-5-2-7-2"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-xs font-bold text-text-main">Open Source Issues</h3>
            <p class="text-[10px] text-text-muted">Report bugs on GitHub</p>
          </div>
        </a>
      </div>
    </div>

    <!-- Form Column -->
    <div class="md:col-span-2 glass-card p-6 rounded-2xl">
      <h3 class="text-sm font-bold uppercase tracking-wider text-text-main border-b border-border-card pb-2 mb-4">Send a Message</h3>
      
      <form class="space-y-4" onsubmit="event.preventDefault(); window.showToast('Message sent! We will reply shortly.', 'success'); this.reset();">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="tool-label text-xs">Your Name</label>
            <input type="text" required placeholder="e.g. Jane Doe" class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs" />
          </div>
          <div>
            <label class="tool-label text-xs">Email Address</label>
            <input type="email" required placeholder="e.g. jane@example.com" class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs" />
          </div>
        </div>

        <div>
          <label class="tool-label text-xs">Subject</label>
          <input type="text" required placeholder="Bug report / Feature suggestion" class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs" />
        </div>

        <div>
          <label class="tool-label text-xs">Message Details</label>
          <textarea required rows="5" placeholder="Tell us what you'd like to share or report..." class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs focus:outline-none focus:border-primary/50"></textarea>
        </div>

        <button type="submit" class="tool-btn tool-btn-primary py-2.5 px-6 text-xs flex items-center gap-1.5 cursor-pointer">
          <Send class="h-3.5 w-3.5" /> Submit Form
        </button>
      </form>
    </div>
  </div>
</Layout>
