---
import Layout from '../../layouts/Layout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { CATEGORIES, allTools } from '../../data/tools';
import { ArrowLeft } from '@lucide/astro';

export async function getStaticPaths() {
  return CATEGORIES.map(cat => ({
    params: { slug: cat.id },
    props: { categoryData: cat }
  }));
}

const { categoryData } = Astro.props;
const { slug } = Astro.params;

// Filter tools in this category
const categoryTools = allTools.filter(t => t.category === categoryData.name);
---

<Layout 
  title={`${categoryData.name} - Free Online Utilities | Toolsbawa`}
  description={categoryData.desc}
>
  <div class="mb-6">
    <a href="/categories" class="inline-flex items-center gap-1.5 text-xs text-text-muted hover:text-text-main transition-colors duration-200">
      <ArrowLeft class="h-3.5 w-3.5" /> Back to Categories
    </a>
  </div>

  <div class="py-6 border-b border-border-card mb-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-3xl font-extrabold text-text-main">{categoryData.name}</h1>
      <p class="text-xs sm:text-sm text-text-muted mt-2">{categoryData.desc}</p>
    </div>
    <div class="px-3.5 py-1.5 rounded-full border border-border-card bg-bg-card text-xs font-semibold text-text-muted shrink-0 w-fit">
      {categoryTools.length} Tools Available
    </div>
  </div>

  {categoryTools.length === 0 ? (
    <div class="p-12 text-center border border-border-card rounded-2xl bg-bg-card/50">
      <p class="text-sm text-text-muted">No tools are available in this category yet. Check back soon!</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {categoryTools.map(t => (
        <ToolCard 
          id={t.id}
          name={t.name}
          description={t.description}
          category={t.category}
          icon={t.icon}
        />
      ))}
    </div>
  )}
</Layout>
