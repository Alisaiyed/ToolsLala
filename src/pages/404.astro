---
import Layout from '../layouts/Layout.astro';
import { ArrowLeft, Sparkles } from '@lucide/astro';
---

<Layout 
  title="404 - Page Not Found | Toolsbawa"
  description="Sorry, the page you are looking for does not exist on Toolsbawa."
>
  <div class="max-w-md mx-auto py-16 text-center space-y-6">
    <div class="h-16 w-16 rounded-2xl bg-gradient-to-tr from-primary/10 to-accent/10 border border-primary/20 flex items-center justify-center text-primary mx-auto animate-bounce">
      <Sparkles class="h-8 w-8" />
    </div>
    
    <div class="space-y-2">
      <h1 class="text-4xl font-extrabold text-text-main">404 - Page Not Found</h1>
      <p class="text-xs sm:text-sm text-text-muted leading-relaxed">
        The route or resource you are looking for has been moved, renamed, or is temporarily unavailable.
      </p>
    </div>

    <div class="pt-4">
      <a href="/" class="tool-btn tool-btn-primary py-2.5 px-6 text-xs inline-flex items-center gap-1.5 mx-auto">
        <ArrowLeft class="h-3.5 w-3.5" /> Back to Home
      </a>
    </div>
  </div>
</Layout>
