---
import Layout from '../../layouts/Layout.astro';
import DynamicIcon from '../../components/DynamicIcon.astro';
import { allTools } from '../../data/tools';
import { Star, Share2, CornerDownRight, Play, RotateCcw, Copy, Download, Trash2, ArrowLeft, Sparkles } from '@lucide/astro';

// Import custom tools
import CodePlayground from '../../components/tools/CodePlayground.astro';
import CodeScreenshot from '../../components/tools/CodeScreenshot.astro';
import ImageTool from '../../components/tools/ImageTool.astro';
import DrawingBoard from '../../components/tools/DrawingBoard.astro';
import RestTester from '../../components/tools/RestTester.astro';
import Timers from '../../components/tools/Timers.astro';
import ColorPickerCustom from '../../components/tools/ColorPickerCustom.astro';
import UtilitiesCustom from '../../components/tools/UtilitiesCustom.astro';

export async function getStaticPaths() {
  return allTools.map(tool => ({
    params: { slug: tool.id },
    props: { tool }
  }));
}

const { tool } = Astro.props;
const { slug } = Astro.params;

// Find related tools (same category)
const relatedTools = allTools.filter(t => t.category === tool.category && t.id !== tool.id).slice(0, 5);

// Check if tool is custom-ui based
const isCustom = tool.customHtml === 'true';
---

<Layout 
  title={`${tool.seoTitle} | Toolsbawa`}
  description={tool.seoDescription}
  keywords={tool.keywords.join(', ')}
>
  <div class="mb-4">
    <a href="/tools" class="inline-flex items-center gap-1.5 text-xs text-text-muted hover:text-text-main transition-colors duration-200">
      <ArrowLeft class="h-3.5 w-3.5" /> Back to Tools
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
    <!-- Left Sidebar: Related, History & Favorites -->
    <aside class="space-y-6 order-2 lg:order-1">
      <!-- Related Tools -->
      <div class="glass-card p-5 rounded-2xl">
        <h3 class="text-xs font-bold uppercase tracking-wider text-primary mb-3">Related Utilities</h3>
        <ul class="space-y-2">
          {relatedTools.map(t => (
            <li>
              <a href={`/tools/${t.id}`} class="flex items-center gap-2 p-2 rounded-xl text-xs text-text-muted hover:text-text-main hover:bg-border-card transition-all duration-200">
                <DynamicIcon name={t.icon} class="h-4 w-4" />
                <span class="truncate">{t.name}</span>
              </a>
            </li>
          ))}
          {relatedTools.length === 0 && (
            <p class="text-[11px] text-text-muted">No related tools found.</p>
          )}
        </ul>
      </div>

      <!-- Favorites List (Populated via JS) -->
      <div class="glass-card p-5 rounded-2xl">
        <h3 class="text-xs font-bold uppercase tracking-wider text-text-main mb-3">My Favorites</h3>
        <ul id="favorites-list-container" class="space-y-2">
          <!-- Populated client side -->
        </ul>
      </div>

      <!-- Recent History List (Populated via JS) -->
      <div class="glass-card p-5 rounded-2xl">
        <h3 class="text-xs font-bold uppercase tracking-wider text-text-main mb-3">Recent History</h3>
        <ul id="history-list-container" class="space-y-2">
          <!-- Populated client side -->
        </ul>
      </div>
    </aside>

    <!-- Main Tool Panel Area -->
    <section class="lg:col-span-3 order-1 lg:order-2 space-y-6" data-tool-id={slug}>
      <!-- Tool Header -->
      <div class="glass-panel p-6 rounded-3xl flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <div class="flex items-center gap-2.5">
            <span class="text-[10px] uppercase font-bold tracking-wider text-primary">{tool.category}</span>
            <span class="h-1 w-1 rounded-full bg-border-card"></span>
            <span class="text-[10px] text-text-muted">Runs 100% Client-Side</span>
          </div>
          <h1 class="text-2xl font-extrabold text-text-main mt-1.5">{tool.name}</h1>
          <p class="text-xs sm:text-sm text-text-muted mt-2 max-w-xl leading-relaxed">{tool.description}</p>
        </div>
        <div class="flex gap-2">
          <button 
            class="fav-btn tool-btn tool-btn-secondary p-2.5 rounded-xl border border-border-card flex items-center justify-center cursor-pointer hover:border-amber-500/30"
            data-id={slug}
          >
            <Star class="h-4.5 w-4.5" />
          </button>
          <button 
            id="share-tool-btn"
            class="tool-btn tool-btn-secondary p-2.5 rounded-xl border border-border-card flex items-center justify-center cursor-pointer"
          >
            <Share2 class="h-4.5 w-4.5" />
          </button>
        </div>
      </div>

      <!-- Custom Gemini Banner if applicable -->
      {tool.hasGemini && (
        <div class="p-4 bg-gradient-to-r from-primary/10 to-accent/10 border border-primary/20 rounded-2xl text-xs flex flex-col sm:flex-row sm:items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <Sparkles class="h-4 w-4 text-primary animate-pulse-slow shrink-0" />
            <span class="text-text-main">
              This tool requires a <strong>Gemini API Key</strong> to process queries. Or run in simulated mode.
            </span>
          </div>
          <input 
            type="password" 
            id="gemini-key-input" 
            placeholder="Enter Gemini API Key..." 
            class="px-2.5 py-1 text-[11px] rounded-lg border border-border-card bg-bg-card text-text-main focus:outline-none"
          />
        </div>
      )}

      <!-- Standard Form-Based Tool Layout -->
      {!isCustom && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Inputs / Controls Area -->
          <div class="glass-card p-6 rounded-2xl space-y-4">
            <h2 class="text-sm font-bold uppercase tracking-wider text-text-main border-b border-border-card pb-2 mb-2 flex items-center gap-1.5">
              <CornerDownRight class="h-4 w-4 text-primary" /> Inputs & Parameters
            </h2>

            {tool.controls.map(ctrl => (
              <div class="flex flex-col">
                <label for={`ctrl-${ctrl.id}`} class="tool-label text-xs font-semibold">{ctrl.label}</label>
                
                {ctrl.type === 'textarea' && (
                  <textarea 
                    id={`ctrl-${ctrl.id}`} 
                    placeholder={ctrl.placeholder}
                    rows="6"
                    class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs text-text-main focus:outline-none focus:border-primary/50"
                  >{ctrl.default || ''}</textarea>
                )}

                {ctrl.type === 'text' && (
                  <input 
                    type="text" 
                    id={`ctrl-${ctrl.id}`} 
                    placeholder={ctrl.placeholder}
                    value={ctrl.default || ''}
                    class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs text-text-main focus:outline-none focus:border-primary/50"
                  />
                )}

                {ctrl.type === 'number' && (
                  <input 
                    type="number" 
                    id={`ctrl-${ctrl.id}`} 
                    value={ctrl.default || 0}
                    min={ctrl.min}
                    max={ctrl.max}
                    step={ctrl.step}
                    class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs text-text-main focus:outline-none focus:border-primary/50"
                  />
                )}

                {ctrl.type === 'slider' && (
                  <div class="flex items-center gap-3">
                    <input 
                      type="range" 
                      id={`ctrl-${ctrl.id}`} 
                      value={ctrl.default || 0}
                      min={ctrl.min}
                      max={ctrl.max}
                      step={ctrl.step}
                      class="flex-grow accent-primary"
                    />
                    <span class="text-xs font-mono font-bold text-primary min-w-[24px]" id={`slider-val-${ctrl.id}`}>
                      {ctrl.default}
                    </span>
                  </div>
                )}

                {ctrl.type === 'select' && (
                  <select 
                    id={`ctrl-${ctrl.id}`} 
                    class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs text-text-main focus:outline-none focus:border-primary/50"
                  >
                    {ctrl.options?.map(opt => (
                      <option value={opt.value} selected={opt.value === ctrl.default}>{opt.label}</option>
                    ))}
                  </select>
                )}

                {ctrl.type === 'color' && (
                  <input 
                    type="color" 
                    id={`ctrl-${ctrl.id}`} 
                    value={ctrl.default || '#000000'}
                    class="w-full h-11 p-1 rounded-xl border border-border-card bg-bg-main/30 cursor-pointer"
                  />
                )}

                {ctrl.type === 'checkbox' && (
                  <div class="flex items-center gap-2 mt-1">
                    <input 
                      type="checkbox" 
                      id={`ctrl-${ctrl.id}`} 
                      checked={ctrl.default}
                      class="h-4 w-4 rounded border-border-card text-primary focus:ring-primary accent-primary"
                    />
                    <span class="text-xs text-text-muted">Enable parameter option</span>
                  </div>
                )}
              </div>
            ))}

            <!-- Common Action Buttons -->
            <div class="flex flex-wrap gap-2.5 mt-6 border-t border-border-card pt-4">
              <button id="run-tool-btn" class="tool-btn tool-btn-primary py-2 px-4 text-xs flex items-center gap-1.5">
                <Play class="h-3.5 w-3.5" /> Execute / Run
              </button>
              {tool.placeholderInput && (
                <button id="load-example-btn" class="tool-btn tool-btn-secondary py-2 px-4 text-xs">
                  Load Example
                </button>
              )}
              <button id="clear-tool-btn" class="tool-btn tool-btn-secondary py-2 px-4 text-xs flex items-center gap-1">
                <RotateCcw class="h-3.5 w-3.5" /> Clear
              </button>
            </div>
          </div>

          <!-- Outputs Area -->
          <div class="glass-card p-6 rounded-2xl space-y-4">
            <h2 class="text-sm font-bold uppercase tracking-wider text-text-main border-b border-border-card pb-2 mb-2">
              Results & Outputs
            </h2>

            {tool.outputs.map(out => (
              <div class="flex flex-col relative group/out">
                <div class="flex justify-between items-center mb-2">
                  <label for={`out-${out.id}`} class="tool-label text-xs font-semibold mb-0">{out.label}</label>
                  <div class="flex gap-1">
                    {out.copyable !== false && (
                      <button 
                        class="copy-output-btn p-1 rounded hover:bg-border-card text-text-muted hover:text-text-main transition-all" 
                        data-target={`out-${out.id}`}
                        title="Copy to clipboard"
                      >
                        <Copy class="h-3.5 w-3.5" />
                      </button>
                    )}
                    {out.downloadable && (
                      <button 
                        class="download-output-btn p-1 rounded hover:bg-border-card text-text-muted hover:text-text-main transition-all" 
                        data-target={`out-${out.id}`}
                        data-filename={`${slug}-output.txt`}
                        title="Download as file"
                      >
                        <Download class="h-3.5 w-3.5" />
                      </button>
                    )}
                  </div>
                </div>

                {out.type === 'textarea' && (
                  <textarea 
                    id={`out-${out.id}`} 
                    readonly 
                    rows="8"
                    placeholder="Result will appear here..."
                    class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs text-text-main font-mono focus:outline-none"
                  ></textarea>
                )}

                {out.type === 'text' && (
                  <input 
                    type="text" 
                    id={`out-${out.id}`} 
                    readonly 
                    placeholder="Result..."
                    class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs text-text-main font-mono focus:outline-none"
                  />
                )}

                {out.type === 'preview' && (
                  <div 
                    id={`out-${out.id}`} 
                    class="w-full p-4 rounded-xl border border-border-card bg-bg-main/30 text-xs text-text-main font-mono overflow-auto max-h-[300px] whitespace-pre-wrap"
                  >
                    Result will render here...
                  </div>
                )}

                {out.type === 'canvas' && (
                  <div class="flex items-center justify-center p-4 bg-bg-main/30 rounded-xl border border-border-card">
                    <canvas id={`out-${out.id}`} class="max-w-full h-auto bg-white border border-border-card rounded-lg"></canvas>
                  </div>
                )}

                {out.type === 'custom' && (
                  <div id={`out-${out.id}`} class="w-full rounded-xl p-1">
                    <!-- Dynamic details appended by script -->
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Custom Advanced UI Override Routing -->
      {isCustom && (
        <div class="space-y-6">
          {slug === 'code-playground' && <CodePlayground />}
          {slug === 'code-screenshot-generator' && <CodeScreenshot />}
          {['image-compressor', 'image-resizer', 'image-cropper', 'image-to-base64'].includes(slug) && <ImageTool id={slug} />}
          {['drawing-board', 'whiteboard'].includes(slug) && <DrawingBoard id={slug} />}
          {['api-tester', 'rest-client'].includes(slug) && <RestTester id={slug} />}
          {['pomodoro-timer', 'stopwatch', 'countdown-timer'].includes(slug) && <Timers id={slug} />}
          {['color-picker', 'gradient-generator'].includes(slug) && <ColorPickerCustom id={slug} />}
          {['typing-speed-test', 'notes', 'clipboard', 'invoice-generator', 'resume-builder'].includes(slug) && <UtilitiesCustom id={slug} />}
        </div>
      )}
    </section>
  </div>
</Layout>

<script>
  import { runners } from '../../data/runners';
  import confetti from 'canvas-confetti';

  const toolContainer = document.querySelector('[data-tool-id]');
  const id = toolContainer?.getAttribute('data-tool-id');

  if (id && toolContainer) {
    const runBtn = document.getElementById('run-tool-btn');
    const loadExampleBtn = document.getElementById('load-example-btn');
    const clearBtn = document.getElementById('clear-tool-btn');
    const shareBtn = document.getElementById('share-tool-btn');

    // Recent History Management
    const saveToHistory = () => {
      let history = JSON.parse(localStorage.getItem('toolverse_history') || '[]');
      history = history.filter((x: string) => x !== id);
      history.unshift(id);
      localStorage.setItem('toolverse_history', JSON.stringify(history.slice(0, 10)));
    };
    saveToHistory();

    // Sync Slider text values
    document.querySelectorAll('input[type="range"]').forEach(slider => {
      slider.addEventListener('input', (e) => {
        const valSpan = document.getElementById(`slider-val-${slider.id.replace('ctrl-', '')}`);
        if (valSpan) valSpan.textContent = (e.target as HTMLInputElement).value;
      });
    });

    // Load Example Click
    loadExampleBtn?.addEventListener('click', () => {
      const firstInput = document.querySelector('textarea[id^="ctrl-"]') as HTMLTextAreaElement;
      const firstTextInput = document.querySelector('input[type="text"][id^="ctrl-"]') as HTMLInputElement;
      
      let mockData = 'Sample text data';
      if (id.includes('json')) mockData = '{\n  "name": "Jane Doe",\n  "role": "Lead Architect",\n  "active": true,\n  "skills": ["Astro", "Tailwind", "TypeScript"]\n}';
      else if (id.includes('xml')) mockData = '<user id="101">\n  <name>Jane Doe</name>\n  <role>Lead Architect</role>\n</user>';
      else if (id.includes('csv')) mockData = 'id,name,role,active\n101,Jane Doe,Lead Architect,true\n102,Bob Stone,Engineer,false';
      else if (id.includes('yaml')) mockData = 'user:\n  name: Jane Doe\n  role: Lead Architect\n  active: true';
      else if (id.includes('markdown') || id.includes('md')) mockData = '# Welcome to Toolsbawa\n\n- Local execution\n- Instant previews\n- Secure sandbox';
      
      if (firstInput) {
        firstInput.value = mockData;
      } else if (firstTextInput) {
        firstTextInput.value = 'https://toolsbawa.com/search?query=developer utilities';
      }
      
      // @ts-ignore
      window.showToast?.('Loaded mock example data', 'success');
    });

    // Clear Click
    clearBtn?.addEventListener('click', () => {
      document.querySelectorAll('input[type="text"], textarea').forEach(el => {
        (el as HTMLInputElement | HTMLTextAreaElement).value = '';
      });
      document.querySelectorAll('[id^="out-"]').forEach(el => {
        if (el.tagName === 'DIV') el.innerHTML = '';
        else (el as HTMLTextAreaElement).value = '';
      });
      // @ts-ignore
      window.showToast?.('Cleared inputs & outputs', 'success');
    });

    // Share tool link
    shareBtn?.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href);
      confetti({ particleCount: 30, spread: 40 });
      // @ts-ignore
      window.showToast?.('Tool link copied to clipboard!', 'success');
    });

    // Process Execute Click
    runBtn?.addEventListener('click', async () => {
      const inputs: any = {};
      document.querySelectorAll('[id^="ctrl-"]').forEach(ctrl => {
        const key = ctrl.id.replace('ctrl-', '');
        if (ctrl.tagName === 'INPUT' && (ctrl as HTMLInputElement).type === 'checkbox') {
          inputs[key] = (ctrl as HTMLInputElement).checked;
        } else {
          inputs[key] = (ctrl as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).value;
        }
      });

      const geminiKeyEl = document.getElementById('gemini-key-input') as HTMLInputElement;
      if (geminiKeyEl) inputs['geminiKey'] = geminiKeyEl.value;

      try {
        const runner = runners[id];
        if (runner) {
          runBtn.setAttribute('disabled', 'true');
          runBtn.textContent = 'Processing...';
          
          let result;
          if (id.startsWith('ai-')) {
            result = await executeGeminiRequest(id, inputs);
          } else {
            result = await runner(inputs);
          }
          
          for (let key in result) {
            const outEl = document.getElementById(`out-${key}`);
            if (outEl) {
              if (outEl.tagName === 'TEXTAREA' || outEl.tagName === 'INPUT') {
                (outEl as HTMLTextAreaElement | HTMLInputElement).value = result[key];
              } else {
                outEl.innerHTML = result[key];
              }
            }
          }
          // @ts-ignore
          window.showToast?.('Execution completed successfully!', 'success');
        } else {
          // @ts-ignore
          window.showToast?.('Runner function not found for this tool', 'error');
        }
      } catch (e: any) {
        // @ts-ignore
        window.showToast?.(`Error: ${e.message}`, 'error');
      } finally {
        runBtn.removeAttribute('disabled');
        runBtn.innerHTML = `<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/></svg> Execute / Run`;
      }
    });

    // Copy output buttons listener
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const copyBtn = target.closest('.copy-output-btn');
      if (!copyBtn) return;
      
      const targetId = copyBtn.getAttribute('data-target');
      if (targetId) {
        const el = document.getElementById(targetId) as HTMLTextAreaElement | HTMLInputElement | HTMLDivElement;
        let text = '';
        if (el.tagName === 'TEXTAREA' || el.tagName === 'INPUT') {
          text = (el as HTMLTextAreaElement | HTMLInputElement).value;
        } else {
          text = el.innerText;
        }
        
        if (text && text.trim() !== '') {
          navigator.clipboard.writeText(text);
          confetti({ particleCount: 30, spread: 50, origin: { y: 0.8 } });
          // @ts-ignore
          window.showToast?.('Copied to clipboard!', 'success');
        } else {
          // @ts-ignore
          window.showToast?.('No output content to copy!', 'error');
        }
      }
    });

    // Download output buttons listener
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const dlBtn = target.closest('.download-output-btn');
      if (!dlBtn) return;

      const targetId = dlBtn.getAttribute('data-target');
      const filename = dlBtn.getAttribute('data-filename') || 'output.txt';
      if (targetId) {
        const el = document.getElementById(targetId) as HTMLTextAreaElement | HTMLInputElement | HTMLDivElement;
        let text = '';
        if (el.tagName === 'TEXTAREA' || el.tagName === 'INPUT') {
          text = (el as HTMLTextAreaElement | HTMLInputElement).value;
        } else {
          text = el.innerText;
        }

        if (text && text.trim() !== '') {
          const blob = new Blob([text], { type: 'text/plain' });
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = filename;
          a.click();
          // @ts-ignore
          window.showToast?.('Downloading file...', 'success');
        }
      }
    });
  }

  // AI Gemini requests handler
  async function executeGeminiRequest(toolId: string, inputs: any) {
    const geminiKey = inputs.geminiKey || '';
    let prompt = '';
    
    if (toolId === 'ai-code-generator') {
      prompt = `Generate code for: ${inputs.prompt} in language: ${inputs.language}. Reply with ONLY code inside a markdown block.`;
    } else if (toolId === 'ai-code-explainer') {
      prompt = `Explain the following code snippet step-by-step: ${inputs.code}`;
    } else if (toolId === 'ai-bug-fixer') {
      prompt = `Fix any errors in this code snippet: ${inputs.code}. Error details: ${inputs.error || 'None'}`;
    } else if (toolId === 'ai-readme-generator') {
      prompt = `Write a professional GitHub README.md file for a project called "${inputs.name}" with description: ${inputs.desc}`;
    } else if (toolId === 'ai-sql-generator') {
      prompt = `Write a SQL query in dialect ${inputs.dialect} to do: ${inputs.prompt}`;
    } else if (toolId === 'ai-regex-generator') {
      prompt = `Generate a regular expression pattern for: ${inputs.prompt}. Also provide a quick description of how it matches.`;
    } else if (toolId === 'ai-commit-generator') {
      prompt = `Suggest a Conventional Commit message for this diff: ${inputs.diff}`;
    } else if (toolId === 'ai-prompt-generator') {
      prompt = `Optimize the following prompt for better LLM performance: ${inputs.prompt}`;
    } else if (toolId === 'ai-blog-generator') {
      prompt = `Write a detailed, structured, SEO-friendly blog article on: "${inputs.topic}" utilizing keywords: ${inputs.keywords}`;
    } else if (toolId === 'ai-email-generator') {
      prompt = `Draft a ${inputs.tone} tone email for: ${inputs.context}`;
    } else if (toolId === 'ai-documentation-generator') {
      prompt = `Write clean JSDoc/docstring comments for this code: ${inputs.code}`;
    } else if (toolId === 'ai-unit-test-generator') {
      prompt = `Write unit tests in framework ${inputs.framework} for code: ${inputs.code}`;
    }

    if (!geminiKey) {
      await new Promise(r => setTimeout(r, 1500));
      return getSimulatedAiResponse(toolId, inputs);
    }

    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${geminiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: prompt }] }]
        })
      });
      const data = await response.json();
      const text = data.candidates[0].content.parts[0].text;
      
      if (toolId === 'ai-code-generator' || toolId === 'ai-bug-fixer' || toolId === 'ai-sql-generator' || toolId === 'ai-unit-test-generator') {
        return { result: text, solution: text, sql: text, tests: text };
      }
      if (toolId === 'ai-regex-generator') {
        const regexMatch = text.match(/`([^`]+)`/);
        return { regex: regexMatch ? regexMatch[1] : '\\b[A-Za-z0-9]\\b', explanation: text };
      }
      return { explanation: text, readme: text, commit: text.replace(/`+/g, ''), optimized: text, post: text, email: text, docs: text };
    } catch(e: any) {
      throw new Error(`Gemini API Error: ${e.message}`);
    }
  }

  function getSimulatedAiResponse(toolId: string, inputs: any) {
    if (toolId === 'ai-code-generator') {
      return { result: `\`\`\`typescript\n// [Simulated] Code generated for: ${inputs.prompt}\nexport function processData(data: any) {\n  console.log("Processing:", data);\n  return data;\n}\n\`\`\`` };
    }
    if (toolId === 'ai-code-explainer') {
      return { explanation: `[Simulated] Explanation:\n1. The code defines a module exports scope.\n2. Iterates over inputs collections.\n3. Applies formatting transformations client-side.` };
    }
    if (toolId === 'ai-bug-fixer') {
      return { solution: `\`\`\`javascript\n// [Simulated] Fixed Code\ntry {\n  // Added try-catch encapsulation to prevent crashes\n  const val = JSON.parse(input);\n  return val;\n} catch (e) {\n  console.error("Syntax Error", e);\n}\n\`\`\`` };
    }
    if (toolId === 'ai-readme-generator') {
      return { readme: `# ${inputs.name || 'Toolsbawa'}\n\n${inputs.desc || 'Mock project description.'}\n\n## Installation\n\`\`\`bash\nnpm install\n\`\`\`` };
    }
    if (toolId === 'ai-sql-generator') {
      return { sql: `\`\`\`sql\n-- [Simulated] Query in ${inputs.dialect}\nSELECT id, name, created_at \nFROM users \nORDER BY created_at DESC \nLIMIT 10;\n\`\`\`` };
    }
    if (toolId === 'ai-regex-generator') {
      return { regex: `^[a-zA-Z0-9_-]{3,16}$`, explanation: `1. ^ asserts start of line.\n2. Match alphanumeric boundaries.\n3. {3,16} limits length.` };
    }
    if (toolId === 'ai-commit-generator') {
      return { commit: `feat: add client-side dynamic tool runners` };
    }
    if (toolId === 'ai-prompt-generator') {
      return { optimized: `Act as a senior software architect. Design a comprehensive system plan for: ${inputs.prompt}. Structure with Mermaid diagrams.` };
    }
    if (toolId === 'ai-blog-generator') {
      return { post: `# Mastering ${inputs.topic || 'Web Tools'}\n\nLorem ipsum dolor sit amet, consectetur adipiscing elit. Web development shifts rapidly...` };
    }
    if (toolId === 'ai-email-generator') {
      return { email: `Subject: Follow-up Request\n\nDear recipient,\n\nI hope this email finds you well. I am writing to check up on the status of...` };
    }
    if (toolId === 'ai-documentation-generator') {
      return { docs: `/**\n * Process target operations.\n * @param {string} input - raw parameters.\n * @returns {object} formatted results.\n */` };
    }
    if (toolId === 'ai-unit-test-generator') {
      return { tests: `\`\`\`javascript\n// Test suite written in ${inputs.framework}\ndescribe('Process Suite', () => {\n  test('should handle valid cases', () => {\n    expect(process(true)).toBe(true);\n  });\n});\n\`\`\`` };
    }
    return { result: 'Simulated AI Response' };
  }

  // Populate Favorites & History Sidebars client-side
  const populateSidebars = () => {
    const favsContainer = document.getElementById('favorites-list-container');
    const histContainer = document.getElementById('history-list-container');
    
    let favs = JSON.parse(localStorage.getItem('toolverse_favs') || '[]');
    let history = JSON.parse(localStorage.getItem('toolverse_history') || '[]');

    if (favsContainer) {
      favsContainer.innerHTML = '';
      if (favs.length === 0) {
        favsContainer.innerHTML = '<li class="text-[11px] text-text-muted italic">No favorites added yet</li>';
      } else {
        favs.slice(0, 5).forEach((fid: string) => {
          favsContainer.innerHTML += `
            <li>
              <a href="/tools/${fid}" class="flex items-center gap-2 p-1.5 rounded-lg text-xs text-text-muted hover:text-text-main hover:bg-border-card transition-all truncate">
                ★ <span class="truncate capitalize">${fid.replace(/-/g, ' ')}</span>
              </a>
            </li>
          `;
        });
      }
    }

    if (histContainer) {
      histContainer.innerHTML = '';
      if (history.length === 0) {
        histContainer.innerHTML = '<li class="text-[11px] text-text-muted italic">No recent history</li>';
      } else {
        history.slice(0, 5).forEach((hid: string) => {
          histContainer.innerHTML += `
            <li>
              <a href="/tools/${hid}" class="flex items-center gap-2 p-1.5 rounded-lg text-xs text-text-muted hover:text-text-main hover:bg-border-card transition-all truncate">
                ⏱ <span class="truncate capitalize">${hid.replace(/-/g, ' ')}</span>
              </a>
            </li>
          `;
        });
      }
    }
  };

  populateSidebars();
  window.addEventListener('favs-updated', populateSidebars);
</script>
