---
import Layout from '../layouts/Layout.astro';
import { GitCommit, Tag, Sparkles } from '@lucide/astro';

const updates = [
  {
    version: "v1.0.0",
    date: "July 3, 2026",
    title: "Official Production Release",
    desc: "First stable release of ToolVerse featuring 100+ developer and AI tools working entirely offline and client-side.",
    changes: [
      "Initialized suite with 104 distinct developer calculators, validators, formatters, and generators.",
      "Added official Gemini AI models integration for automated code compilation.",
      "Implemented macOS browser shell styles in Code Screenshot Generator.",
      "Integrated responsive drawing whiteboard with shapes, pencil, and eraser configurations.",
      "Integrated LocalStorage caching to manage user favorites, notepad saves, and history lists."
    ]
  },
  {
    version: "v0.8.0-beta",
    date: "June 25, 2026",
    title: "Beta Launch & UI Tweaks",
    desc: "Beta release incorporating the master base layouts and design systems.",
    changes: [
      "Built glassmorphic UI container elements (glass-card, glass-input, glass-panel).",
      "Created the global search bar command palette supporting Ctrl+K navigation.",
      "Optimized custom print stylesheets for CV Builder and Invoice Generator."
    ]
  }
];
---

<Layout 
  title="Changelog - ToolVerse Updates"
  description="Stay updated with new release versions, bug fixes, custom additions, and improvements to the ToolVerse developer utility suite."
>
  <div class="max-w-3xl mx-auto space-y-12">
    <!-- Header -->
    <div class="text-center py-6">
      <h1 class="text-3xl font-extrabold text-text-main">Changelog & Updates</h1>
      <p class="text-xs sm:text-sm text-text-muted mt-2">Track versions, updates, and newly added tool integrations.</p>
    </div>

    <!-- Timeline -->
    <div class="relative border-l-2 border-border-card ml-4 pl-8 space-y-12">
      {updates.map(up => (
        <div class="relative">
          <!-- Timeline point marker -->
          <span class="absolute -left-12 top-1.5 bg-primary/10 border-2 border-primary text-primary rounded-full p-1.5 flex items-center justify-center">
            <Tag class="h-3.5 w-3.5" />
          </span>

          <div class="glass-card p-6 rounded-2xl space-y-4">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <div>
                <span class="px-2.5 py-1 text-xs font-bold rounded-lg bg-primary/10 text-primary border border-primary/20">
                  {up.version}
                </span>
                <h2 class="text-lg font-bold text-text-main mt-2.5">{up.title}</h2>
              </div>
              <span class="text-xs text-text-muted">{up.date}</span>
            </div>
            
            <p class="text-xs sm:text-sm text-text-muted leading-relaxed">{up.desc}</p>
            
            <div class="border-t border-border-card pt-3 mt-2">
              <h4 class="text-xs font-bold text-text-main uppercase tracking-wider mb-2">Updates list:</h4>
              <ul class="list-disc list-inside text-xs text-text-muted space-y-1.5 pl-1 leading-relaxed">
                {up.changes.map(c => (
                  <li>{c}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
