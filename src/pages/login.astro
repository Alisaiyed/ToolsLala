---
import Layout from '../layouts/Layout.astro';
import { Sparkles } from '@lucide/astro';
---

<Layout 
  title="Log In - Toolsbawa"
  description="Log in to your Toolsbawa dashboard to sync your favorites list and preset histories."
>
  <div class="max-w-md mx-auto py-12">
    <div class="glass-panel p-8 rounded-3xl border border-border-card bg-bg-card/50 shadow-2xl space-y-6">
      
      <!-- Brand Title -->
      <div class="text-center space-y-2">
        <div class="inline-flex h-10 w-10 rounded-xl bg-gradient-to-tr from-primary to-accent items-center justify-center text-white shadow-md shadow-primary/20 mb-2">
          <Sparkles class="h-5.5 w-5.5" />
        </div>
        <h1 class="text-2xl font-extrabold text-text-main">Welcome to Toolsbawa</h1>
        <p class="text-xs text-text-muted">Access synchronized favorites, preset saves, and AI configurations.</p>
      </div>

      <!-- Demo Login Form -->
      <form class="space-y-4" onsubmit="event.preventDefault(); alert('Login simulated successfully!'); window.location.href='/';">
        <div class="flex flex-col gap-1.5">
          <label for="email" class="tool-label text-xs font-semibold">Email Address</label>
          <input 
            type="email" 
            id="email" 
            required 
            placeholder="name@company.com" 
            class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs text-text-main focus:outline-none focus:border-primary/50"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <div class="flex justify-between items-center">
            <label for="password" class="tool-label text-xs font-semibold mb-0">Password</label>
            <a href="#" class="text-[10px] text-primary hover:underline">Forgot password?</a>
          </div>
          <input 
            type="password" 
            id="password" 
            required 
            placeholder="••••••••" 
            class="w-full p-3 rounded-xl border border-border-card bg-bg-main/30 text-xs text-text-main focus:outline-none focus:border-primary/50"
          />
        </div>

        <button type="submit" class="tool-btn tool-btn-primary w-full py-3 text-xs font-bold rounded-xl cursor-pointer">
          Sign In
        </button>
      </form>

      <!-- Divider -->
      <div class="relative flex py-2 items-center">
        <div class="flex-grow border-t border-border-card/50"></div>
        <span class="flex-shrink mx-4 text-[10px] text-text-muted uppercase font-bold tracking-wider">Or continue with</span>
        <div class="flex-grow border-t border-border-card/50"></div>
      </div>

      <!-- Social Logins -->
      <div class="grid grid-cols-2 gap-3">
        <button 
          onclick="alert('Google Auth Mock!'); window.location.href='/';"
          class="tool-btn tool-btn-secondary py-2.5 text-xs font-bold rounded-xl flex items-center justify-center gap-2 cursor-pointer"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.24 10.285V13.4h6.887C18.2 15.614 15.645 18 12.24 18c-3.86 0-7-3.14-7-7s3.14-7 7-7c1.7 0 3.3.6 4.6 1.7l2.4-2.4C17.3 1.7 14.9 1 12.24 1c-5.5 0-10 4.5-10 10s4.5 10 10 10c5.5 0 9.8-3.9 9.8-9.3 0-.6 0-1.1-.1-1.4H12.24z"/>
          </svg> Google
        </button>
        <button 
          onclick="alert('GitHub Auth Mock!'); window.location.href='/';"
          class="tool-btn tool-btn-secondary py-2.5 text-xs font-bold rounded-xl flex items-center justify-center gap-2 cursor-pointer"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg> GitHub
        </button>
      </div>

      <!-- Sign Up Prompt -->
      <div class="text-center text-xs text-text-muted mt-4">
        Don't have an account? <a href="#" class="text-primary hover:underline font-semibold">Sign up free</a>
      </div>
    </div>
  </div>
</Layout>
