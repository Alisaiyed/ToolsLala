---
import { Search, Command, X } from '@lucide/astro';
import { allTools } from '../data/tools';
---

<div 
  id="command-palette" 
  class="fixed inset-0 z-50 flex items-start justify-center p-4 sm:p-10 md:p-20 bg-bg-main/70 backdrop-blur-md hidden"
  data-tools={JSON.stringify(allTools)}
>
  <!-- Modal box -->
  <div class="relative w-full max-w-2xl rounded-2xl glass-card border border-border-card shadow-2xl overflow-hidden mt-10 opacity-0 transform scale-95">
    <!-- Header Input Container -->
    <div id="palette-search-container" class="flex items-center gap-3 px-4 py-3 border-b border-border-card bg-bg-card/50 transition-all duration-300">
      <Search class="h-5 w-5 text-text-muted" />
      <input 
        id="palette-search-input"
        type="text" 
        placeholder="Type a tool name or category... (e.g. JWT, Base64)"
        class="flex-1 bg-transparent text-sm text-text-main placeholder-text-muted focus:outline-none"
      />
      <kbd class="hidden sm:flex items-center gap-0.5 px-1.5 py-0.5 rounded-lg border border-border-card bg-bg-card font-mono text-[9px] text-text-muted keyboard-shortcut">
        <span>ESC</span>
      </kbd>
      <button id="palette-close-btn" class="text-text-muted hover:text-text-main transition-colors duration-200">
        <X class="h-4 w-4" />
      </button>
    </div>

    <!-- Results body -->
    <div class="max-h-[360px] overflow-y-auto p-2 space-y-1.5" id="palette-results-list">
      <!-- Will be populated dynamically by JavaScript -->
    </div>
  </div>
</div>

<script>
  interface Tool {
    id: string;
    name: string;
    description: string;
    category: string;
  }

  const palette = document.getElementById('command-palette');
  const trigger = document.getElementById('search-trigger');
  const input = document.getElementById('palette-search-input') as HTMLInputElement;
  const list = document.getElementById('palette-results-list');
  const closeBtn = document.getElementById('palette-close-btn');
  const searchContainer = document.getElementById('palette-search-container');

  let tools: Tool[] = [];
  try {
    tools = JSON.parse(palette?.dataset.tools || '[]');
  } catch (e) {}

  let highlightedIndex = 0;
  let matchesList: Tool[] = [];

  const openPalette = () => {
    // @ts-ignore
    if (typeof gsap === 'undefined') {
      palette?.classList.remove('hidden');
      input.value = '';
      input.focus();
      updateResults();
      return;
    }

    palette?.classList.remove('hidden');
    input.value = '';
    input.focus();
    updateResults();

    const modal = palette?.querySelector('.glass-card');
    // @ts-ignore
    gsap.fromTo(modal, 
      { scale: 0.95, opacity: 0 }, 
      { scale: 1, opacity: 1, duration: 0.35, ease: "power3.out" }
    );
  };

  const closePalette = () => {
    const modal = palette?.querySelector('.glass-card');
    // @ts-ignore
    if (typeof gsap !== 'undefined') {
      // @ts-ignore
      gsap.to(modal, { 
        scale: 0.95, 
        opacity: 0, 
        duration: 0.2, 
        ease: "power3.in",
        onComplete: () => {
          palette?.classList.add('hidden');
        }
      });
    } else {
      palette?.classList.add('hidden');
    }
  };

  trigger?.addEventListener('click', openPalette);
  closeBtn?.addEventListener('click', closePalette);

  palette?.addEventListener('click', (e) => {
    if (e.target === palette) closePalette();
  });

  window.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openPalette();
    }
    if (e.key === 'Escape') {
      closePalette();
    }
  });

  // Focus glow handlers
  input?.addEventListener('focus', () => {
    if (searchContainer) {
      searchContainer.style.borderColor = 'var(--primary)';
      searchContainer.style.boxShadow = '0 0 0 3px var(--primary-glow)';
    }
  });
  input?.addEventListener('blur', () => {
    if (searchContainer) {
      searchContainer.style.borderColor = 'var(--border-card)';
      searchContainer.style.boxShadow = 'none';
    }
  });

  const updateResults = () => {
    const q = input.value.trim().toLowerCase();
    
    if (q === '') {
      matchesList = tools.slice(0, 8);
    } else {
      matchesList = tools.filter(t => 
        t.name.toLowerCase().includes(q) || 
        t.category.toLowerCase().includes(q) || 
        t.description.toLowerCase().includes(q)
      );
    }

    highlightedIndex = 0;
    renderResults();
  };

  const renderResults = () => {
    if (!list) return;
    list.innerHTML = '';
    
    if (matchesList.length === 0) {
      list.innerHTML = `<div class="p-8 text-center text-xs text-text-muted animate-fade-in">No tools matched your search query.</div>`;
      return;
    }

    matchesList.forEach((t, i) => {
      const isSelected = i === highlightedIndex;
      const el = document.createElement('a');
      el.href = `/tools/${t.id}`;
      el.className = `flex items-center justify-between p-3 rounded-xl transition-all duration-200 opacity-0 translate-y-2 ${
        isSelected ? 'bg-primary/10 border-l-4 border-primary text-primary pl-4' : 'hover:bg-border-card text-text-main'
      }`;
      el.innerHTML = `
        <div>
          <div class="text-sm font-semibold">${t.name}</div>
          <div class="text-xs text-text-muted truncate max-w-[400px] mt-0.5">${t.description}</div>
        </div>
        <div class="flex items-center gap-1.5 text-xs text-primary font-medium">
          <span>${t.category}</span>
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      `;
      list.appendChild(el);
    });

    // Stagger render results
    // @ts-ignore
    if (typeof gsap !== 'undefined') {
      // @ts-ignore
      gsap.to(list.children, {
        opacity: 1,
        y: 0,
        stagger: 0.03,
        duration: 0.25,
        ease: "power2.out"
      });
    } else {
      Array.from(list.children).forEach((child: any) => {
        child.style.opacity = '1';
        child.style.transform = 'none';
      });
    }
  };

  input?.addEventListener('input', updateResults);

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      highlightedIndex = (highlightedIndex + 1) % matchesList.length;
      renderResults();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      highlightedIndex = (highlightedIndex - 1 + matchesList.length) % matchesList.length;
      renderResults();
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (matchesList[highlightedIndex]) {
        window.location.href = `/tools/${matchesList[highlightedIndex].id}`;
      }
    }
  });
</script>
