<div class="fixed inset-0 -z-50 overflow-hidden pointer-events-none">
  <!-- Glowing gradient orbs -->
  <div class="absolute top-[10%] left-[-10%] w-[45rem] h-[45rem] rounded-full bg-gradient-to-tr from-primary/10 to-accent/10 blur-[120px] animate-float opacity-70"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[50rem] h-[50rem] rounded-full bg-gradient-to-br from-accent/10 to-primary/10 blur-[130px] animate-float opacity-60" style="animation-delay: -3s;"></div>
  
  <!-- Subtle overlay pattern grid -->
  <div class="absolute inset-0 bg-grid opacity-[0.02] dark:opacity-[0.03]"></div>
</div>
