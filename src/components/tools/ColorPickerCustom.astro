---
import { Eye, Copy, Sliders, Palette } from '@lucide/astro';

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <!-- Controls Panel -->
  <div class="glass-card p-6 rounded-2xl space-y-4">
    <h3 class="text-sm font-bold uppercase tracking-wider text-text-main border-b border-border-card pb-2">
      {id === 'color-picker' ? 'Color Settings' : 'Gradient Settings'}
    </h3>

    {id === 'color-picker' && (
      <div class="space-y-4">
        <!-- Native Eyedropper API (If supported) -->
        <button id="eyedropper-btn" class="w-full tool-btn tool-btn-primary py-2.5 text-xs flex items-center justify-center gap-1.5 hidden">
          <Eye class="h-4 w-4" /> Open Eyedropper Inspector
        </button>

        <!-- Color input -->
        <div>
          <label class="tool-label text-xs">Choose Color</label>
          <input type="color" id="picker-color-input" value="#6366f1" class="w-full h-12 p-1 bg-bg-main/30 rounded-xl border border-border-card cursor-pointer" />
        </div>
      </div>
    )}

    {id === 'gradient-generator' && (
      <div class="space-y-4">
        <!-- Colors inputs -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="tool-label text-xs">Color Start</label>
            <input type="color" id="grad-start" value="#6366f1" class="w-full h-11 p-1 bg-bg-main/30 rounded-xl border border-border-card cursor-pointer" />
          </div>
          <div>
            <label class="tool-label text-xs">Color End</label>
            <input type="color" id="grad-end" value="#a855f7" class="w-full h-11 p-1 bg-bg-main/30 rounded-xl border border-border-card cursor-pointer" />
          </div>
        </div>

        <!-- Angle -->
        <div>
          <label class="tool-label text-xs">Gradient Angle (deg)</label>
          <div class="flex items-center gap-3">
            <input type="range" id="grad-angle" min="0" max="360" value="45" class="flex-grow accent-primary" />
            <span id="grad-angle-span" class="text-xs font-mono font-bold text-primary">45°</span>
          </div>
        </div>

        <!-- Type -->
        <div>
          <label class="tool-label text-xs">Gradient Type</label>
          <select id="grad-type" class="w-full p-2.5 rounded-xl border border-border-card bg-bg-main/30 text-xs focus:outline-none">
            <option value="linear">Linear Gradient</option>
            <option value="radial">Radial Gradient</option>
          </select>
        </div>
      </div>
    )}
  </div>

  <!-- Preview / Output Panel -->
  <div class="glass-card p-6 rounded-2xl flex flex-col justify-between">
    <h3 class="text-sm font-bold uppercase tracking-wider text-text-main border-b border-border-card pb-2 mb-4">
      Visual Preview & CSS Output
    </h3>

    <!-- Color visual preview -->
    <div 
      id="color-preview-box" 
      class="flex-grow rounded-xl border border-border-card min-h-[140px] flex items-center justify-center transition-all duration-200"
      style="background-color: #6366f1;"
    >
      <span id="color-preview-text" class="text-xs font-mono font-bold text-white px-2 py-1 bg-black/40 rounded shadow">#6366f1</span>
    </div>

    <!-- Output format values -->
    <div class="mt-4 space-y-2 text-xs">
      {id === 'color-picker' && (
        <div class="grid grid-cols-3 gap-2">
          <div class="flex flex-col">
            <label class="text-[10px] uppercase font-bold text-text-muted">HEX</label>
            <input type="text" id="val-hex" readonly value="#6366f1" class="p-2 rounded border border-border-card bg-bg-main/30 font-mono text-[10px]" />
          </div>
          <div class="flex flex-col">
            <label class="text-[10px] uppercase font-bold text-text-muted">RGB</label>
            <input type="text" id="val-rgb" readonly value="rgb(99, 102, 241)" class="p-2 rounded border border-border-card bg-bg-main/30 font-mono text-[10px]" />
          </div>
          <div class="flex flex-col">
            <label class="text-[10px] uppercase font-bold text-text-muted">HSL</label>
            <input type="text" id="val-hsl" readonly value="hsl(239, 84%, 67%)" class="p-2 rounded border border-border-card bg-bg-main/30 font-mono text-[10px]" />
          </div>
        </div>
      )}

      {id === 'gradient-generator' && (
        <div class="flex flex-col gap-1.5">
          <label class="text-[10px] uppercase font-bold text-text-muted">CSS Background Value</label>
          <textarea id="val-css-gradient" readonly rows="3" class="w-full p-2 rounded border border-border-card bg-bg-main/30 font-mono text-[10px] focus:outline-none"></textarea>
          <button id="copy-gradient-btn" class="tool-btn tool-btn-secondary py-1 text-xs flex items-center justify-center gap-1 mt-1">
            <Copy class="h-3 w-3" /> Copy CSS Code
          </button>
        </div>
      )}
    </div>
  </div>
</div>

<script define:vars={{ toolId: id }}>
  const previewBox = document.getElementById('color-preview-box');
  const previewText = document.getElementById('color-preview-text');

  // Helper HSL converter
  const hexToHsl = (hex) => {
    let r = parseInt(hex.substring(1,3), 16) / 255;
    let g = parseInt(hex.substring(3,5), 16) / 255;
    let b = parseInt(hex.substring(5,7), 16) / 255;
    let max = Math.max(r, g, b), min = Math.min(r, g, b);
    let h, s, l = (max + min) / 2;

    if (max === min) {
      h = s = 0;
    } else {
      let d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      switch(max){
        case r: h = (g - b) / d + (g < b ? 6 : 0); break;
        case g: h = (b - r) / d + 2; break;
        case b: h = (r - g) / d + 4; break;
      }
      h /= 6;
    }
    return `hsl(${Math.round(h*360)}, ${Math.round(s*100)}%, ${Math.round(l*100)}%)`;
  };

  // Helper RGB converter
  const hexToRgb = (hex) => {
    let r = parseInt(hex.substring(1,3), 16);
    let g = parseInt(hex.substring(3,5), 16);
    let b = parseInt(hex.substring(5,7), 16);
    return `rgb(${r}, ${g}, ${b})`;
  };

  if (toolId === 'color-picker') {
    const colorInput = document.getElementById('picker-color-input');
    const eyedropperBtn = document.getElementById('eyedropper-btn');
    const valHex = document.getElementById('val-hex');
    const valRgb = document.getElementById('val-rgb');
    const valHsl = document.getElementById('val-hsl');

    // Check Eyedropper API support
    if (window.EyeDropper) {
      eyedropperBtn?.classList.remove('hidden');
      eyedropperBtn?.addEventListener('click', async () => {
        try {
          const eyeDropper = new EyeDropper();
          const result = await eyeDropper.open();
          updateColor(result.sRGBHex);
        } catch (e) {}
      });
    }

    const updateColor = (hex) => {
      if (colorInput) colorInput.value = hex;
      if (previewBox) previewBox.style.backgroundColor = hex;
      if (previewText) previewText.textContent = hex;

      if (valHex) valHex.value = hex;
      if (valRgb) valRgb.value = hexToRgb(hex);
      if (valHsl) valHsl.value = hexToHsl(hex);
    };

    colorInput?.addEventListener('input', (e) => updateColor(e.target.value));

    // Copy handlers for HEX/RGB/HSL
    [valHex, valRgb, valHsl].forEach(input => {
      input?.addEventListener('click', () => {
        navigator.clipboard.writeText(input.value);
        window.showToast?.(`Copied: ${input.value}`, 'success');
      });
    });
  }

  if (toolId === 'gradient-generator') {
    const startInput = document.getElementById('grad-start');
    const endInput = document.getElementById('grad-end');
    const angleInput = document.getElementById('grad-angle');
    const angleSpan = document.getElementById('grad-angle-span');
    const typeSelect = document.getElementById('grad-type');
    const valCss = document.getElementById('val-css-gradient');
    const copyGradBtn = document.getElementById('copy-gradient-btn');

    const updateGradient = () => {
      const start = startInput.value;
      const end = endInput.value;
      const angle = angleInput.value;
      const type = typeSelect.value;

      if (angleSpan) angleSpan.textContent = `${angle}°`;

      let gradientString = '';
      if (type === 'linear') {
        gradientString = `linear-gradient(${angle}deg, ${start}, ${end})`;
      } else {
        gradientString = `radial-gradient(circle, ${start}, ${end})`;
      }

      if (previewBox) previewBox.style.background = gradientString;
      if (previewText) previewText.textContent = gradientString.substring(0, 30) + '...';
      if (valCss) valCss.value = `background: ${gradientString};`;
    };

    [startInput, endInput, angleInput, typeSelect].forEach(input => {
      input?.addEventListener('input', updateGradient);
      input?.addEventListener('change', updateGradient);
    });

    copyGradBtn?.addEventListener('click', () => {
      if (valCss?.value) {
        navigator.clipboard.writeText(valCss.value);
        window.showToast?.('Gradient CSS copied!', 'success');
      }
    });

    updateGradient();
  }
</script>
